# ─────────────────────────────────────────────────────────────
# TaskFlow environment variables
# Copy to `.env` for local dev, or set in Render → Environment.
# ─────────────────────────────────────────────────────────────

# ─── Core Django ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ─── Database ─────────────────────────────────────────────────
# Leave unset to use SQLite locally. In production, set this to your
# Postgres Internal Database URL from Render.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Python version (Render only) ─────────────────────────────
# PYTHON_VERSION=3.12.7

# ─── Site URL (used in email links) ───────────────────────────
SITE_URL=https://taskflow-criztech.onrender.com/

# ─── Email / SMTP ─────────────────────────────────────────────
# Leave EMAIL_HOST unset to print emails to the console (dev mode).
# For production, set these — Gmail example shown below.
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail" → paste the 16-char string below
#
# Other providers (SendGrid, Mailgun, Resend, AWS SES, Postmark) work
# the same way — just use their SMTP host + credentials.
#
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=TaskFlow <your-email@gmail.com>
